# T1D server configuration
T1D_API_PORT=8790
T1D_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
T1D_COOKIE_SECURE=false
T1D_DATA_DIR=
T1D_SITE_URL=http://localhost:3002
VITE_SITE_URL=http://localhost:3002
T1D_CRON_SECRET=
T1D_EXPOSE_RESET_TOKEN=false

# Durable storage (recommended for production)
DATABASE_URL=

# Optional monitoring
VITE_SENTRY_DSN=

# Google OAuth (optional)
T1D_GOOGLE_CLIENT_ID=
T1D_GOOGLE_CLIENT_SECRET=
T1D_GOOGLE_REDIRECT_URI=

# Rate limiting (recommended for production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Dexcom
DEXCOM_USE_LIVE=false
DEXCOM_CLIENT_ID=
DEXCOM_CLIENT_SECRET=
DEXCOM_REDIRECT_URI=http://localhost:8790/api/dexcom/oauth/callback
DEXCOM_AUTHORIZE_URL=https://sandbox-api.dexcom.com/v2/oauth2/login
DEXCOM_TOKEN_URL=https://sandbox-api.dexcom.com/v2/oauth2/token
DEXCOM_API_BASE_URL=https://sandbox-api.dexcom.com
DEXCOM_EGV_PATH=/v3/users/self/egvs
DEXCOM_DEVICE_PATH=/v2/users/self/devices
DEXCOM_HTTP_TIMEOUT_MS=10000
DEXCOM_HTTP_MAX_RETRIES=2
DEXCOM_HTTP_RETRY_DELAY_MS=500
DEXCOM_POLL_INTERVAL_SECONDS=60
DEXCOM_DEGRADED_POLL_INTERVAL_SECONDS=180
DEXCOM_RATE_LIMIT_POLL_INTERVAL_SECONDS=300
T1D_BACKGROUND_SYNC_INTERVAL_MS=15000
